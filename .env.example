# ─── Anthropic API ───────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Resend Email API ─────────────────────────────────────────────────────────
# Get your key at https://resend.com
# For local testing you can use the free tier (100 emails/day)
RESEND_API_KEY=your_resend_api_key_here

# Sender address — must be from a Resend-verified domain.
# Use "onboarding@resend.dev" for sandbox testing (only sends to your own verified email).
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Dr. ARS Assessment

# Admin email: receives automated results on every submission
ADMIN_EMAIL=arsheikh540@gmail.com

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
